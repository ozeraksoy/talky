<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Talky - Altyazı Oluşturucu</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

  <!-- Header -->
  <div class="header">
    <div class="header-left">
      <span class="logo">🎙</span>
      <div>
        <div class="app-name">Talky</div>
        <div class="app-sub">Altyazı Oluşturucu</div>
      </div>
    </div>
    <button id="btnSettings" class="icon-btn" title="Ayarlar">⚙</button>
  </div>

  <!-- Settings Panel (hidden by default) -->
  <div id="settingsPanel" class="settings-panel hidden">
    <div class="section-title">OpenAI API Anahtarı</div>
    <div class="api-row">
      <input type="password" id="apiKey" placeholder="sk-..." autocomplete="off" spellcheck="false">
      <button id="btnToggleKey" class="icon-btn" title="Göster/Gizle">👁</button>
    </div>
    <div id="apiStatus" class="api-status"></div>
    <p class="hint">
      API anahtarınız yalnızca bu cihazda ve yerel bellekte saklanır.<br>
      <a href="#" id="linkOpenAI">OpenAI hesabınızdan alın →</a>
    </p>

    <div class="section-title" style="margin-top:12px">ffmpeg Durumu</div>
    <div id="ffmpegStatus" class="ffmpeg-status">Kontrol ediliyor...</div>
    <p class="hint" id="ffmpegHint" style="display:none">
      ffmpeg gereklidir. Kurulum için README dosyasına bakın.
    </p>
  </div>

  <!-- Clip Detection -->
  <div class="section">
    <div class="section-header">
      <span class="section-title">Aktif Klip</span>
      <div class="btn-group">
        <button id="btnGetClipAtPlayhead" class="btn-sm" title="Oynatma kafasındaki klibi al">⏺ Kafadaki</button>
        <button id="btnGetSelectedClip" class="btn-sm" title="Seçili klibi al">☑ Seçili</button>
      </div>
    </div>

    <div id="clipInfoBox" class="clip-info-box">
      <div class="clip-placeholder">
        <span class="placeholder-icon">🎬</span>
        <p>Klip bilgisi alınmadı.<br>Yukarıdaki butonlardan birini kullanın.</p>
      </div>
    </div>
  </div>

  <!-- Transcription Settings -->
  <div class="section">
    <div class="section-title">Transkripsiyon Ayarları</div>

    <div class="form-row">
      <label>Kaynak Dil</label>
      <select id="sourceLanguage">
        <option value="">Otomatik Tespit</option>
        <option value="tr" selected>Türkçe</option>
        <option value="en">İngilizce</option>
        <option value="de">Almanca</option>
        <option value="fr">Fransızca</option>
        <option value="es">İspanyolca</option>
        <option value="it">İtalyanca</option>
        <option value="ru">Rusça</option>
        <option value="ar">Arapça</option>
        <option value="ja">Japonca</option>
        <option value="ko">Korece</option>
        <option value="zh">Çince</option>
        <option value="pt">Portekizce</option>
        <option value="nl">Hollandaca</option>
        <option value="pl">Lehçe</option>
        <option value="sv">İsveççe</option>
      </select>
    </div>

    <div class="form-row">
      <label class="checkbox-label">
        <input type="checkbox" id="translateEnabled">
        <span class="checkmark"></span>
        Çeviri Yap
      </label>
    </div>

    <div id="targetLangRow" class="form-row hidden">
      <label>Hedef Dil</label>
      <select id="targetLanguage">
        <option value="en" selected>İngilizce</option>
        <option value="tr">Türkçe</option>
        <option value="de">Almanca</option>
        <option value="fr">Fransızca</option>
        <option value="es">İspanyolca</option>
        <option value="it">İtalyanca</option>
        <option value="ru">Rusça</option>
        <option value="ar">Arapça</option>
        <option value="ja">Japonca</option>
        <option value="ko">Korece</option>
        <option value="zh">Çince (Basitleştirilmiş)</option>
        <option value="pt">Portekizce</option>
        <option value="nl">Hollandaca</option>
        <option value="pl">Lehçe</option>
        <option value="uk">Ukraynaca</option>
      </select>
    </div>
  </div>

  <!-- Transcribe Button -->
  <div class="action-area">
    <button id="btnTranscribe" class="btn-primary" disabled>
      <span class="btn-icon">🎙</span>
      <span id="btnTranscribeText">Transkripsiyon Başlat</span>
    </button>
  </div>

  <!-- Progress -->
  <div id="progressArea" class="progress-area hidden">
    <div class="progress-bar-wrap">
      <div id="progressBar" class="progress-bar" style="width:0%"></div>
    </div>
    <div class="progress-info">
      <span class="spinner">◌</span>
      <span id="progressText">İşleniyor...</span>
    </div>
  </div>

  <!-- Error -->
  <div id="errorBox" class="error-box hidden">
    <span class="error-icon">⚠</span>
    <span id="errorText"></span>
    <button id="btnDismissError" class="icon-btn-sm">✕</button>
  </div>

  <!-- Results -->
  <div id="resultsSection" class="section hidden">
    <div class="section-header">
      <span class="section-title">Sonuçlar</span>
      <div class="btn-group">
        <button id="btnShowOriginal" class="btn-sm active" title="Orijinal metni göster">TR</button>
        <button id="btnShowTranslated" class="btn-sm hidden" title="Çeviriyi göster">ÇEVİRİ</button>
      </div>
    </div>

    <div id="segmentsList" class="segments-list"></div>

    <div class="segments-stats">
      <span id="segmentsCount">0 segment</span>
      <span id="totalDuration"></span>
    </div>
  </div>

  <!-- Export -->
  <div id="exportSection" class="section hidden">
    <div class="section-title">Dışa Aktar</div>

    <div class="export-options">
      <label class="radio-label">
        <input type="radio" name="exportContent" value="original" checked>
        <span>Orijinal Transkripsiyon</span>
      </label>
      <label class="radio-label hidden" id="radioTranslatedLabel">
        <input type="radio" name="exportContent" value="translated">
        <span>Çeviri</span>
      </label>
    </div>

    <div class="export-buttons">
      <button id="btnSaveSRT" class="btn-export">
        <span>💾</span> SRT Dosyası Kaydet
      </button>
      <button id="btnImportPP" class="btn-export">
        <span>📥</span> Premiere'e İçe Aktar
      </button>
    </div>

    <div id="exportStatus" class="export-status hidden"></div>
  </div>

  <!-- CSInterface kütüphanesi -->
  <script src="../lib/CSInterface.js"></script>
  <script src="app.js"></script>
</body>
</html>
